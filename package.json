{
  "name": "mtg-graph",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:cards": "tsx pipeline/index.ts",
    "refresh:cards": "tsx pipeline/index.ts --refresh",
    "rule:coverage": "tsx pipeline/scripts/rule-coverage.ts",
    "rule:mine": "tsx pipeline/scripts/rule-mine.ts",
    "deploy:artifact": "tsx pipeline/scripts/deploy-artifact.ts",
    "test": "vitest run && npm --prefix app test && npm --prefix app run build",
    "test:pipeline": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
